{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user profile for all users",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["carrier", "provider", "admin"] },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "city": { "type": "string" }
      },
      "required": ["uid", "role", "phone"]
    },
    "Carrier": {
      "title": "Carrier",
      "description": "Specific details for truck owners/drivers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "cnic": { "type": "string" },
        "truckType": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "licenseUrl": { "type": "string" },
        "vehicleDocUrl": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "whatsapp": { "type": "string" }
      },
      "required": ["uid", "truckType", "vehicleNumber", "cnic"]
    },
    "Load": {
      "title": "Load",
      "description": "A shipment posted by a load provider",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "providerId": { "type": "string" },
        "pickupCity": { "type": "string" },
        "dropCity": { "type": "string" },
        "pickupAddress": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "weight": { "type": "string" },
        "truckTypeRequired": { "type": "string" },
        "productType": { "type": "string" },
        "priceOffer": { "type": "number" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "applied", "in-transit", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "assignedCarrierId": { "type": "string" }
      },
      "required": ["providerId", "pickupCity", "dropCity", "weight", "truckTypeRequired", "status"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Main user collection"
    },
    "carriers": {
      "schema": "Carrier",
      "description": "Carrier profile details"
    },
    "loads": {
      "schema": "Load",
      "description": "Load listings"
    }
  }
}
